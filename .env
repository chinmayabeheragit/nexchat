# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/chat_engine
MONGO_URI_TEST=mongodb://localhost:27017/chat_engine_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Encryption
E2E_ENCRYPTION_KEY=32_char_encryption_key_here_!!!!

# Notification
NOTIFICATION_DEBOUNCE_MS=30000
TYPING_DEBOUNCE_MS=1500
CART_DEBOUNCE_MS=2000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Queue
QUEUE_CONCURRENCY=5
MAX_RETRY_ATTEMPTS=3
